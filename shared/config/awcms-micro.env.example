# Deprecated compatibility example.
#
# Use `shared/config/awcms-geospatial.env.example` and
# `shared/config/awcms-geospatialTemplate.env.example` as the canonical files.
# Keep host-provided values here as documentation only.
# Do not commit secrets. Copy the real values into `.env` locally.

# Repo paths and job routing
GEOFIRST_REPO_ROOT=/home/data/dev_geospatial/geo-first
GEOFIRST_PROJECTS_DIR=/home/data/dev_geospatial/geo-first/projects
GEOFIRST_SHARED_DIR=/home/data/dev_geospatial/geo-first/shared
GEOFIRST_PROJECT_FILE=/home/data/dev_geospatial/geo-first/shared/qgis/batas_admin_kobar.qgs
GEOFIRST_OUTPUT_DIR=/home/data/dev_geospatial/geo-first/projects/faskes-kobar/output
GEOFIRST_PROJECT_DIR=/home/data/dev_geospatial/geo-first/projects/faskes-kobar
GEOFIRST_SHAPEFILE_PATH=/home/data/dev_geospatial/geo-first/projects/faskes-kobar/shapefiles/faskes.shp
GEOFIRST_KECAMATAN_SHP=/home/data/dev_geospatial/geo-first/shared/shapefiles/kecamatan.shp
GEOFIRST_DESA_SHP=/home/data/dev_geospatial/geo-first/shared/shapefiles/desa.shp

# Map job defaults
GEOFIRST_DEFAULT_PROJECT=faskes-kobar
GEOFIRST_DEFAULT_SECTOR=health
GEOFIRST_DEFAULT_OUTPUT_FORMATS=png,pdf,svg

# Host-side AWCMS / EmDash references
# AWCMS_MIRROR_BASE_URL=
# AWCMS_MICRO_PUBLIC_URL=
# AWCMS_MICRO_INTERNAL_URL=
# AWCMS_MICRO_API_TOKEN=
# EMDASH_PLUGIN_ID=
# EMDASH_WORKER_NAME=

# Optional job queue or storage bindings supplied by the host
# AWCMS_JOB_QUEUE=
# AWCMS_JOB_BUCKET=
# AWCMS_JOB_D1_DATABASE=

# Canonical environment template for the awcms-geospatial plugin.
# Keep secrets out of the repository.

AWCMS_GEOSPATIAL_REPO_ROOT=/home/data/dev_geospatial/geo-first
AWCMS_GEOSPATIAL_PROJECTS_DIR=/home/data/dev_geospatial/geo-first/projects
AWCMS_GEOSPATIAL_SHARED_DIR=/home/data/dev_geospatial/geo-first/shared
AWCMS_GEOSPATIAL_PROJECT_FILE=/home/data/dev_geospatial/geo-first/shared/qgis/batas_admin_kobar.qgs
AWCMS_GEOSPATIAL_OUTPUT_DIR=/home/data/dev_geospatial/geo-first/projects/faskes-kobar/output
AWCMS_GEOSPATIAL_PROJECT_DIR=/home/data/dev_geospatial/geo-first/projects/faskes-kobar
AWCMS_GEOSPATIAL_SHAPEFILE_PATH=/home/data/dev_geospatial/geo-first/projects/faskes-kobar/shapefiles/faskes.shp
AWCMS_GEOSPATIAL_KECAMATAN_SHP=/home/data/dev_geospatial/geo-first/shared/shapefiles/kecamatan.shp
AWCMS_GEOSPATIAL_DESA_SHP=/home/data/dev_geospatial/geo-first/shared/shapefiles/desa.shp
AWCMS_GEOSPATIAL_DEFAULT_PROJECT=faskes-kobar
AWCMS_GEOSPATIAL_DEFAULT_SECTOR=health
AWCMS_GEOSPATIAL_DEFAULT_OUTPUT_FORMATS=png,pdf,svg

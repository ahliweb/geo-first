      <gmd:abstract>
        
        
        <gco:CharacterString>Dataset fasilitas kesehatan Kabupaten Kotawaringin Barat untuk peta tematik, analisis akses layanan, dan publikasi Geoportal BIG/PALAPA. Basis peta menggunakan batas administrasi kabupaten, kecamatan, dan desa/kelurahan.</gco:CharacterString>
        
      
      </gmd:abstract>
      

      
      <gmd:purpose>
        
        
        <gco:CharacterString>Menyediakan data batas administrasi untuk visualisasi awal, perencanaan, pendidikan, dan analisis spasial non-hukum di Kabupaten Kotawaringin Barat.</gco:CharacterString>
        
      
      </gmd:purpose>
      

      
      <gmd:credit>
        
        
